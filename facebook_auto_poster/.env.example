# ──────────────────────────────────────────────
# Facebook Auto-Poster — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────

# Contraseña compartida para TODAS las cuentas Facebook
FB_PASSWORD=your_shared_password_here

# Cuentas a cargar (comma-separated, lowercase). Dejar vacío si se gestiona todo desde /admin.
ACCOUNT_NAMES=

# --- Cuentas (fallback de primer arranque — en producción usar el panel /admin) ---
# Estructura por cuenta (reemplazar 'nombre' por el nombre real, en mayúsculas como prefijo):
#   NOMBRE_EMAIL=usuario@ejemplo.com          ← o NOMBRE_PHONE=+521234567890
#   NOMBRE_GROUPS=123456789012345,987654321   ← IDs reales de grupos Facebook (opcional)
#
# IMPORTANTE: No uses IDs de prueba (111111, 222222, etc.) — la validación los rechaza.

# NOTA: chromedriver NO es necesario. Patchright gestiona su propio Chromium.
# Ejecutar una vez: patchright install chromium

# Execution mode: "sequential" (default) o "parallel" (asyncio bounded concurrency)
EXECUTION_MODE=sequential

# --- API Server ---
# Puerto donde escucha el servidor Flask (0.0.0.0:{API_PORT})
API_PORT=5000

# Separar API y Worker en procesos distintos (0=monolítico, 1=separado)
# Si 1: arrancar api_main.py y worker_main.py por separado
SPLIT_PROCESSES=0

# Intervalo en segundos entre ciclos de polling del worker (default: 5)
WORKER_POLL_INTERVAL=5

# Máximo de workers paralelos (default: 2)
MAX_CONCURRENT_WORKERS=2

# Logging estructurado JSON via structlog (0=texto plano, 1=JSON)
# Requiere structlog~=24.0. Útil para Grafana Loki / ELK.
STRUCTURED_LOGGING=0

# Exponer métricas Prometheus en /metrics (0=desactivado, 1=activo)
METRICS_ENABLED=0

# Reparación adaptativa de selectores DOM via Scrapling + Gemini (0=off, 1=on)
# Cuando un XPath deja de funcionar, intenta repararlo automáticamente.
ADAPTIVE_SELECTORS=0

# Activar router FastAPI en /v2/* además del Flask principal (0=off, 1=on)
USE_FASTAPI=0

# Clave para acceder al panel de administración web (/admin)
ADMIN_KEY=cambia_esta_clave_admin

# Clave de firma para las cookies de sesión del panel admin.
# DEBE ser DISTINTA de ADMIN_KEY — si fueran iguales, un atacante con una
# cookie de sesión podría deducir ADMIN_KEY. Generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=cambia_esta_clave_sesion_unica

# Clave que OpenClaw debe enviar en cada request como header X-API-Key
OPENCLAW_API_KEY=cambia_esta_clave_openclaw

# --- Gemini API (comentarios humanos en publicaciones ajenas) ---
# Obtener claves gratis en https://aistudio.google.com/apikey
#
# GEMINI_API_KEYS: lista de claves separadas por coma (sin espacios).
# Si una agota quota (429), el sistema rota automáticamente a la siguiente.
# Ejemplo: "clave1,clave2,clave3"
# Si vacío, el sistema desactiva los comentarios automáticamente.
#
# Fallback legacy: si GEMINI_API_KEYS no existe pero GEMINI_API_KEY existe,
# se usa esa (para compatibilidad con setups antiguos).
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
