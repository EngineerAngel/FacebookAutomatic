# ──────────────────────────────────────────────
# Facebook Auto-Poster — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────

# Contraseña compartida para TODAS las cuentas Facebook
FB_PASSWORD=your_shared_password_here

# Comma-separated account names (lowercase recommended)
ACCOUNT_NAMES=maria,zofia,elena

# --- Account: maria ---
MARIA_EMAIL=maria@example.com
MARIA_GROUPS=111111111111,222222222222,333333333333

# --- Account: zofia ---
ZOFIA_EMAIL=zofia@example.com
ZOFIA_GROUPS=444444444444,555555555555,666666666666

# --- Account: elena ---
ELENA_EMAIL=elena@example.com
ELENA_GROUPS=777777777777,888888888888,999999999999

# NOTA: chromedriver NO es necesario. Patchright gestiona su propio Chromium.
# Ejecutar una vez: patchright install chromium

# Perfil de Chrome persistente (opcional — mejorará en Fase 2.1 con user_data_dir)
# Dejar vacío para que Patchright use perfil temporal (recomendado)
# Si se desea un perfil persistente del sistema, especificar ruta según OS:
#   Mac:    /Users/TU_USUARIO/Library/Application Support/Google/Chrome/Default
#   Ubuntu: /home/TU_USUARIO/.config/google-chrome/Default
#   Windows: C:\Users\TU_USUARIO\AppData\Local\Google\Chrome\User Data\Default
CHROME_PROFILE_PATH=
CHROME_PROFILE_NAME=Default

# Execution mode: "sequential" (default) or "parallel"
EXECUTION_MODE=sequential

# Post text (opcional — si vacío, debe enviarse via POST /post desde OpenClaw)
POST_TEXT=

# --- API Server ---
# Puerto donde escucha el servidor Flask (0.0.0.0:{API_PORT})
API_PORT=5000

# Clave para acceder al panel de administración web (/admin)
ADMIN_KEY=cambia_esta_clave_admin

# Clave de firma para las cookies de sesión del panel admin.
# DEBE ser DISTINTA de ADMIN_KEY — si fueran iguales, un atacante con una
# cookie de sesión podría deducir ADMIN_KEY. Generar con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=cambia_esta_clave_sesion_unica

# Clave que OpenClaw debe enviar en cada request como header X-API-Key
OPENCLAW_API_KEY=cambia_esta_clave_openclaw

# --- Gemini API (comentarios humanos en publicaciones ajenas) ---
# Obtener claves gratis en https://aistudio.google.com/apikey
#
# GEMINI_API_KEYS: lista de claves separadas por coma (sin espacios).
# Si una agota quota (429), el sistema rota automáticamente a la siguiente.
# Ejemplo: "clave1,clave2,clave3"
# Si vacío, el sistema desactiva los comentarios automáticamente.
#
# Fallback legacy: si GEMINI_API_KEYS no existe pero GEMINI_API_KEY existe,
# se usa esa (para compatibilidad con setups antiguos).
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
