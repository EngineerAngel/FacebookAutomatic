# ──────────────────────────────────────────────
# Facebook Auto-Poster — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.
# ──────────────────────────────────────────────

# Comma-separated account names (lowercase recommended)
ACCOUNT_NAMES=maria,zofia,elena

# --- Account: maria ---
MARIA_EMAIL=your_email@example.com
MARIA_PASSWORD=your_password_here
MARIA_GROUPS=111111111111,222222222222,333333333333

# --- Account: zofia ---
ZOFIA_EMAIL=your_email@example.com
ZOFIA_PASSWORD=your_password_here
ZOFIA_GROUPS=444444444444,555555555555,666666666666

# --- Account: elena ---
ELENA_EMAIL=your_email@example.com
ELENA_PASSWORD=your_password_here
ELENA_GROUPS=777777777777,888888888888,999999999999

# Optional: path to chromedriver binary (leave empty to auto-detect)
CHROMEDRIVER_PATH=

# Perfil de Chrome persistente (evita CAPTCHAs al reusar sesión)
# En Windows suele ser: C:\Users\TU_USUARIO\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE_PATH=C:\Users\ag464\AppData\Local\Google\Chrome\User Data
# Nombre del perfil (Default, Profile 1, Profile 2, etc.)
CHROME_PROFILE_NAME=Default

# Execution mode: "sequential" (default) or "parallel"
EXECUTION_MODE=sequential

# Post text (opcional — si vacío, debe enviarse via POST /post desde OpenClaw)
POST_TEXT=

# --- API Server ---
# Puerto donde escucha el servidor Flask (0.0.0.0:{API_PORT})
API_PORT=5000

