# ──────────────────────────────────────────────
# Facebook Auto-Poster — Variables de Entorno
# ──────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# NUNCA hagas commit del archivo .env al control de versiones.
# ──────────────────────────────────────────────

# Nombres de cuentas separados por comas (se recomienda minúsculas)
ACCOUNT_NAMES=maria,zofia,elena

# --- Cuenta: maria ---
MARIA_EMAIL=tu_email@ejemplo.com
MARIA_PASSWORD=tu_contraseña_aqui
MARIA_GROUPS=111111111111,222222222222,333333333333

# --- Cuenta: zofia ---
ZOFIA_EMAIL=tu_email@ejemplo.com
ZOFIA_PASSWORD=tu_contraseña_aqui
ZOFIA_GROUPS=444444444444,555555555555,666666666666

# --- Cuenta: elena ---
ELENA_EMAIL=tu_email@ejemplo.com
ELENA_PASSWORD=tu_contraseña_aqui
ELENA_GROUPS=777777777777,888888888888,999999999999

# Opcional: ruta al binario chromedriver (déjalo vacío para auto-detectar)
CHROMEDRIVER_PATH=

# Modo de ejecución: "sequential" (predeterminado) o "parallel"
EXECUTION_MODE=sequential

# Texto del post (si está vacío, el script te lo pedirá en tiempo de ejecución)
POST_TEXT=
